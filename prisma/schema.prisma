// Radio station simulator — aligns with docs/PRD.md §7
// Local: SQLite file. Vercel/serverless: use Turso (libsql) or another persisted store; no durable local disk.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Settings {
  id                     Int     @id @default(autoincrement())
  spotifyPlaylistId      String? @map("spotify_playlist_id")
  currentSongCount       Int     @default(0) @map("current_song_count")
  /// Songs per block before a station ID: 5 or 6. Null until first broadcast cycle.
  stationBreakTarget     Int?    @map("station_break_target")
  /// Legacy; OAuth tokens use structured columns below.
  lastAuthToken          String? @map("last_auth_token")
  spotifyAccessToken     String? @map("spotify_access_token")
  spotifyRefreshToken    String? @map("spotify_refresh_token")
  /// Unix timestamp (ms) when spotifyAccessToken expires. BigInt: ms exceeds 32-bit Int.
  spotifyAccessExpiresAt BigInt? @map("spotify_access_expires_at")

  @@map("Settings")
}

model StationID {
  id        Int    @id @default(autoincrement())
  fileName  String @map("file_name")
  filePath  String @unique @map("file_path")
  playCount Int    @default(0) @map("play_count")

  @@map("StationIDs")
}
